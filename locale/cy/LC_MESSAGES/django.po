msgstr ""
"Eich etholaeth newydd yw <strong>%(new_name)s</strong>. Gallwch weld eich "
"etholaeth newydd ar y map isod."

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:158
#, python-format
msgid "Your %(division_unit_cap)s has changed"
msgstr "Mae eich %(division_unit_cap)s wedi newid."

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:163
#, python-format
msgid ""
"At the last parliamentary election your %(division_unit)s was "
"<strong>%(old_name)s</strong>. On %(date)s it will be <strong>%(new_name)s</"
"strong>. View the map below to understand these changes."
msgstr ""
"Yn yr etholiad seneddol diwethaf, <strong>%(old_name)s</strong> oedd eich "
"%(division_unit)s chi. Ar %(date)s, <strong>%(new_name)s</strong> fydd yr "
"enw. Edrychwch ar y map isod i ddeall y newidiadau hyn."

