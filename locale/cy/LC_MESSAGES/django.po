msgid ""
"There's been a boundary review in your area. Please see below for details."
msgstr ""
"Mae adolygiad ffiniau wedi digwydd yn eich ardal chi. Mae’r manylion i’w "
"cael isod."

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:48
msgid "Looking for election information?"
msgstr "Chwilio am wybodaeth am yr etholiad?"

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:48
