msgstr "Mae siâp eich %(division_unit_cap)s wedi newid."

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:116
#, python-format
msgid ""
"Your %(division_unit)s, <strong>%(old_name)s</strong>, has changed shape "
"since the last election. These changes might be minor but will affect some "
"electors. View the map below to understand these changes. Your "
"%(division_unit)s’s name has not been changed."
msgstr ""
"Mae siâp eich %(division_unit)s, <strong>%(old_name)s</strong>, wedi newid "
"ers yr etholiad diwethaf. Er mai newidiadau bychain yw’r rhain, byddan nhw’n "
"cael effaith ar rai etholwyr. Edrychwch ar y map isod i ddeall y newidiadau "
"hyn. Nid yw enw eich %(division_unit)s wedi ei newid."

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:131
#, python-format
msgid "Your %(division_unit_cap)s has a new name"
msgstr "Mae gan eich %(division_unit_cap)s enw newydd"

#: wcivf/apps/elections/templates/elections/boundary_reviews_view.html:136
#, python-format
msgid ""
